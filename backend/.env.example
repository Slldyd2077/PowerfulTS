# PowerfulTS 后端配置
# 复制本文件为 .env 并填入实际值

# ── 原生数据层 (SQLite + SQLAlchemy async) ──
# 默认零依赖文件库; 改 DATABASE_URL 可切 PostgreSQL/MySQL
DATABASE_URL=sqlite+aiosqlite:///./data/powerfults.db

# ── 原生 TS3 ServerQuery 直连 (监控 / 频道租赁写操作) ──
# ServerQuery 账号在 TS3 服务端创建 (监控需 clientlist/channellist 读权限;
# 频道租赁另需 channelcreate/channeledit/channeldelete/clientmove 写权限)
TS3_HOST=127.0.0.1
TS3_QUERY_PORT=10011
TS3_QUERY_USER=
TS3_QUERY_PASSWORD=
TS3_SID=1

# ── TSMusicBot 音乐引擎 (Docker :3000) ──
# 在 TSMusicBot WebUI 登录所用的账号密码 + bot 实例 id
TSMUSIC_URL=http://127.0.0.1:3000
TSMUSIC_USER=
TSMUSIC_PASSWORD=
TSMUSIC_BOT_ID=

# ── 网易云音乐 API (可选，TSMusicBot 已内置) ──
NETEASE_API_URL=http://127.0.0.1:3001

# ── NapCat QQ 机器人 (可选，好友上线提醒推送; OneBot HTTP API) ──
# 留空 NAPCAT_URL 则禁用推送；需在 NapCat 开启 HTTP 服务并允许调用 send_private_msg
NAPCAT_URL=http://127.0.0.1:3000
NAPCAT_TOKEN=

# ── CORS 允许的前端来源（逗号分隔；生产部署请改为实际域名）──
CORS_ORIGINS=http://localhost:5173
