# PowerfulTS 后端配置
# 复制本文件为 .env 并填入实际值

# ── 通道 1: S-QC-Bot (监控/用户/频道) ──
SQC_BOT_URL=http://127.0.0.1:8080

# ── 通道 2: TS3AudioBot (音乐引擎) ──
TS3AB_URL=http://127.0.0.1:58913

# 认证凭据获取方式：
#   在 TS3 客户端私聊 bot 发送  !api token
#   bot 回复的字符串形如  "uA0U7t4PBxdJ5TLnarsOHQh4/tY=:abcdef1234567890..."
#   冒号前 = UID  → 填 TS3AB_BOT_UID
#   冒号后 = TOKEN → 填 TS3AB_API_TOKEN
TS3AB_BOT_UID=
TS3AB_API_TOKEN=
TS3AB_DEFAULT_BOT_ID=0

# ── 原生数据层 (SQLite + SQLAlchemy async) ──
# 默认零依赖文件库; 改 DATABASE_URL 可切 PostgreSQL/MySQL
DATABASE_URL=sqlite+aiosqlite:///./data/powerfults.db

# ── 原生 TS3 ServerQuery 直连 (监控 / 频道租赁写操作) ──
# ServerQuery 账号在 TS3 服务端创建 (监控需 clientlist/channellist 读权限;
# 频道租赁另需 channelcreate/channeledit/channeldelete/clientmove 写权限)
TS3_HOST=127.0.0.1
TS3_QUERY_PORT=10011
TS3_QUERY_USER=
TS3_QUERY_PASSWORD=
TS3_SID=1

# ── 网易云音乐 API (本地 NeteaseCloudMusicApi 服务) ──
# npm i NeteaseCloudMusicApi && node node_modules/NeteaseCloudMusicApi/app.js
NETEASE_API_URL=http://127.0.0.1:3000
